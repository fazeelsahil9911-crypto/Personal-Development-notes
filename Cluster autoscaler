---

apiVersion: apps/v1
kind: Deployment
metadata:
  name: cluster-autoscaler
  namespace: kube-system
spec:
  replicas: 1
  selector:
    matchLabels:
      app: cluster-autoscaler
  template:
    metadata: 
      labels:
        app: cluster-autoscaler
    spec:
      containers:
      - name: cluster-autoscaler
        image: k8s.gcr.io/autoscaler/custer-autoscaler:v1.29.0
        command:
        - ./cluster-autscaler
        - --cloud-provider=aws
        - --nodes=2:10:nodegroup-name
