YAML

apiVersion: v1
kind: ConfigMap
metadata:
  name: aws-auth
  namespce: kube-system
data:
  mapRoles:  |
    - rolearn: arn:aws:iam::<account-id>:role/<NodeInstanceRole>
      username: system:node:{{EC2PrivateDNSName}}
      groups:
        - system:bootstrappers
        - system:nodes
  mapUsers:    |
   - userarn: arn:aws:iam::<account-id>:user/<AdminUser>
     username: admin
     groups:
      - system:masters
      
