## Job ##

apiVersion: batch/v1
kind: Job
metadata:
  name: pathnex-job
spec:
  template:
    spec:
      containers:
      - name: busybox
        image: busybox
        command: ["sh", "-c", "echo Hello, Kubernetes!"]
      restartPolicy: Never

## CronJob ##

apiVersion: batch/v1
kind: Cronjob
metadata:
  name: pathnex-cronjob
spec:
  schedule: "*/5 * * * *"
  jobTemplate:
    spec:
      template:
        spec:
          containers:
          - name: busybox
            image: busybox
            command: ["sh", "-c", "echo Hello, Kubernetes!"]
          restartPolicy: OnFailure

## Service ## 

apiVersion: v1
kind: Service
metadata:
  name: pathnex-service
spec:
  selector:
    app: pathnex
  ports:
  - protocol: TCP 
    port: 80 
    targetPort: 80
  type: ClusterIP

## INGRESS ##

apiVersion: netwroking.k8s.io/v1
kind: Ingress
metadata:
  name: pathnex-ingress
spec:
  rules:
  - host: pathnex.com
    http: 
      paths:
      - path: /
        pathType: Prefix
        backend:
          service:
            name: pathnex-service
            port:
              number: 80

## ConfigMap  ##

apiVersion: v1
kind: ConfigMap
metadata:
  name: pathnecx-configmap
data:
  key1: value1
  key2: value2

##  Secret  ##

apiVersion: v1
kind: Secret
metadata:
  name: pathnex-secret
type: Opaque
data:
  username: YWRtaW4= # "admin"
